{
  "openapi": "3.0.3",
  "info": {
    "title": "OKX Solana Discover API",
    "version": "2.0.0",
    "description": "Solana trending CA discovery sourced from the OKX Web3 token screener. Returns address-first lists that can be fed into GMGN token detail endpoints."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3002",
      "description": "Local API server"
    }
  ],
  "tags": [
    {
      "name": "OKX Discover",
      "description": "Trending CA lists from OKX"
    }
  ],
  "paths": {
    "/api/discover/okx/solana/trending": {
      "get": {
        "tags": [
          "OKX Discover"
        ],
        "summary": "Fetch Solana trending CA lists from OKX",
        "parameters": [
          {
            "name": "timeframes",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "5m,1h,4h,24h",
              "example": "5m,1h,4h,24h"
            }
          },
          {
            "name": "itemLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 80
            }
          },
          {
            "name": "ttlMs",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 60000,
              "default": 8000
            }
          },
          {
            "name": "refresh",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trending CA payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkxDiscoverResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OkxDiscoverItem": {
        "type": "object",
        "properties": {
          "rank": {
            "type": "integer",
            "format": "int64",
            "description": "Preview rank"
          },
          "tokenAddress": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "description": "Logo url",
            "nullable": true
          },
          "source": {
            "type": "string",
            "example": "okx"
          },
          "protocol": {
            "type": "string",
            "description": "Protocol",
            "nullable": true
          },
          "launchpad": {
            "type": "string",
            "description": "Launchpad",
            "nullable": true
          },
          "marketCapUsd": {
            "type": "number",
            "description": "Market cap",
            "nullable": true
          },
          "liquidityUsd": {
            "type": "number",
            "description": "Liquidity",
            "nullable": true
          },
          "volumeUsd": {
            "type": "number",
            "description": "Selected timeframe volume",
            "nullable": true
          },
          "totalVolumeUsd": {
            "type": "number",
            "description": "Total volume",
            "nullable": true
          },
          "totalTxns": {
            "type": "number",
            "description": "Transactions",
            "nullable": true
          },
          "totalHolders": {
            "type": "number",
            "description": "Holders",
            "nullable": true
          },
          "recentVisitors": {
            "type": "number",
            "description": "Search count / interest",
            "nullable": true
          },
          "priceChangePct": {
            "type": "number",
            "description": "Price change",
            "nullable": true
          }
        },
        "required": [
          "rank",
          "tokenAddress",
          "symbol",
          "name",
          "avatarUrl",
          "source",
          "protocol",
          "launchpad",
          "marketCapUsd",
          "liquidityUsd",
          "volumeUsd",
          "totalVolumeUsd",
          "totalTxns",
          "totalHolders",
          "recentVisitors",
          "priceChangePct"
        ]
      },
      "OkxDiscoverTimeframe": {
        "type": "object",
        "properties": {
          "timeframe": {
            "type": "string",
            "enum": [
              "5m",
              "1h",
              "4h",
              "24h"
            ]
          },
          "totalRows": {
            "type": "integer",
            "format": "int64",
            "description": "Total OKX rows for the timeframe"
          },
          "tokenAddresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OkxDiscoverItem"
            }
          }
        },
        "required": [
          "timeframe",
          "totalRows",
          "tokenAddresses",
          "items"
        ]
      },
      "OkxDiscoverResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "fetchedAt": {
            "type": "string",
            "format": "date-time"
          },
          "cachedAt": {
            "type": "string",
            "format": "date-time"
          },
          "cacheAgeMs": {
            "type": "number",
            "description": "Cache age"
          },
          "request": {
            "type": "object",
            "properties": {
              "chain": {
                "type": "string",
                "example": "sol"
              },
              "source": {
                "type": "string",
                "example": "okx"
              },
              "timeframes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "5m",
                    "1h",
                    "4h",
                    "24h"
                  ]
                }
              },
              "itemLimit": {
                "type": "integer",
                "format": "int64",
                "description": "Preview item limit"
              }
            },
            "required": [
              "chain",
              "source",
              "timeframes",
              "itemLimit"
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "chain": {
                "type": "string",
                "example": "sol"
              },
              "source": {
                "type": "string",
                "example": "okx"
              },
              "timeframes": {
                "type": "object",
                "properties": {
                  "5m": {
                    "$ref": "#/components/schemas/OkxDiscoverTimeframe"
                  },
                  "1h": {
                    "$ref": "#/components/schemas/OkxDiscoverTimeframe"
                  },
                  "4h": {
                    "$ref": "#/components/schemas/OkxDiscoverTimeframe"
                  },
                  "24h": {
                    "$ref": "#/components/schemas/OkxDiscoverTimeframe"
                  }
                },
                "additionalProperties": {
                  "$ref": "#/components/schemas/OkxDiscoverTimeframe"
                }
              }
            },
            "required": [
              "chain",
              "source",
              "timeframes"
            ]
          }
        },
        "required": [
          "ok",
          "fetchedAt",
          "cachedAt",
          "cacheAgeMs",
          "request",
          "data"
        ]
      }
    }
  }
}
