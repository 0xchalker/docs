{
  "openapi": "3.0.3",
  "info": {
    "title": "Padre Solana Discover API",
    "version": "2.0.0",
    "description": "Solana CA discovery sourced from live Padre tab/timeframe selections. The crawler matches visible DOM rows to websocket `gazes` snapshots to recover full token addresses."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3002",
      "description": "Local API server"
    }
  ],
  "tags": [
    {
      "name": "Padre Discover",
      "description": "Dex, New, Users, and Padre Trending CA lists"
    }
  ],
  "paths": {
    "/api/discover/padre/solana/tokens": {
      "get": {
        "tags": [
          "Padre Discover"
        ],
        "summary": "Fetch Padre CA lists by tab and timeframe",
        "parameters": [
          {
            "name": "tab",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "trending",
                "dex",
                "new",
                "users"
              ],
              "default": "trending"
            }
          },
          {
            "name": "timeframe",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1m",
                "5m",
                "30m",
                "1h"
              ],
              "default": "5m"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60,
              "default": 30
            }
          },
          {
            "name": "ttlMs",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 60000,
              "default": 8000
            }
          },
          {
            "name": "refresh",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Padre CA payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PadreDiscoverResponse"
                }
              }
            }
          },
          "503": {
            "description": "Crawler unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PadreDiscoverResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PadreDiscoverStatus": {
        "type": "object",
        "properties": {
          "connected": {
            "type": "boolean"
          },
          "ready": {
            "type": "boolean"
          },
          "pageUrl": {
            "type": "string",
            "description": "Page url",
            "nullable": true
          },
          "profileDir": {
            "type": "string",
            "description": "Profile directory",
            "nullable": true
          },
          "lastFrameAt": {
            "type": "string",
            "description": "Last websocket frame",
            "nullable": true
          },
          "lastActionAt": {
            "type": "string",
            "description": "Last selection time",
            "nullable": true
          },
          "lastMatchScore": {
            "type": "number",
            "description": "DOM match score",
            "nullable": true
          },
          "lastSelectedTab": {
            "type": "string",
            "description": "Last selected tab",
            "nullable": true
          },
          "lastSelectedTimeframe": {
            "type": "string",
            "description": "Last selected timeframe",
            "nullable": true
          },
          "lastError": {
            "type": "string",
            "description": "Last crawler error",
            "nullable": true
          },
          "snapshotsTracked": {
            "type": "integer",
            "format": "int64",
            "description": "Stored snapshots"
          },
          "cacheEntries": {
            "type": "integer",
            "format": "int64",
            "description": "Cache entries"
          }
        },
        "required": [
          "connected",
          "ready",
          "pageUrl",
          "profileDir",
          "lastFrameAt",
          "lastActionAt",
          "lastMatchScore",
          "lastSelectedTab",
          "lastSelectedTimeframe",
          "lastError",
          "snapshotsTracked",
          "cacheEntries"
        ]
      },
      "PadreDiscoverItem": {
        "type": "object",
        "properties": {
          "rank": {
            "type": "integer",
            "format": "int64",
            "description": "Row rank"
          },
          "tokenAddress": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "description": "Token avatar",
            "nullable": true
          },
          "source": {
            "type": "string",
            "example": "padre"
          },
          "protocol": {
            "type": "string",
            "description": "Protocol",
            "nullable": true
          },
          "launchpad": {
            "type": "string",
            "description": "Launchpad",
            "nullable": true
          },
          "marketCapUsd": {
            "type": "number",
            "description": "Market cap",
            "nullable": true
          },
          "liquidityUsd": {
            "type": "number",
            "description": "Liquidity",
            "nullable": true
          },
          "volumeUsd": {
            "type": "number",
            "description": "Selected timeframe volume",
            "nullable": true
          },
          "totalVolumeUsd": {
            "type": "number",
            "description": "Lifetime volume",
            "nullable": true
          },
          "totalTxns": {
            "type": "number",
            "description": "Transactions",
            "nullable": true
          },
          "totalHolders": {
            "type": "number",
            "description": "Holders",
            "nullable": true
          },
          "recentVisitors": {
            "type": "number",
            "description": "Recent visitors",
            "nullable": true
          },
          "priceChangePct": {
            "type": "number",
            "description": "Selected timeframe price change",
            "nullable": true
          }
        },
        "required": [
          "rank",
          "tokenAddress",
          "symbol",
          "name",
          "avatarUrl",
          "source",
          "protocol",
          "launchpad",
          "marketCapUsd",
          "liquidityUsd",
          "volumeUsd",
          "totalVolumeUsd",
          "totalTxns",
          "totalHolders",
          "recentVisitors",
          "priceChangePct"
        ]
      },
      "PadreDiscoverResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "fetchedAt": {
            "type": "string",
            "format": "date-time"
          },
          "request": {
            "type": "object",
            "properties": {
              "chain": {
                "type": "string",
                "example": "sol"
              },
              "source": {
                "type": "string",
                "example": "padre"
              },
              "tab": {
                "type": "string",
                "enum": [
                  "trending",
                  "dex",
                  "new",
                  "users"
                ]
              },
              "timeframe": {
                "type": "string",
                "enum": [
                  "1m",
                  "5m",
                  "30m",
                  "1h"
                ]
              },
              "limit": {
                "type": "integer",
                "format": "int64",
                "description": "Requested limit"
              }
            },
            "required": [
              "chain",
              "source",
              "tab",
              "timeframe",
              "limit"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/PadreDiscoverStatus"
          },
          "data": {
            "type": "object",
            "properties": {
              "chain": {
                "type": "string",
                "example": "sol"
              },
              "source": {
                "type": "string",
                "example": "padre"
              },
              "tab": {
                "type": "string",
                "enum": [
                  "trending",
                  "dex",
                  "new",
                  "users"
                ]
              },
              "timeframe": {
                "type": "string",
                "enum": [
                  "1m",
                  "5m",
                  "30m",
                  "1h"
                ]
              },
              "totalRows": {
                "type": "integer",
                "format": "int64",
                "description": "Rows in the matched snapshot"
              },
              "tokenAddresses": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PadreDiscoverItem"
                }
              },
              "matchedSnapshot": {
                "type": "object",
                "properties": {
                  "requestId": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Matched request id",
                    "nullable": true
                  },
                  "score": {
                    "type": "number",
                    "description": "Match score"
                  },
                  "visibleSequence": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "requestId",
                  "score",
                  "visibleSequence"
                ]
              }
            },
            "required": [
              "chain",
              "source",
              "tab",
              "timeframe",
              "totalRows",
              "tokenAddresses",
              "items",
              "matchedSnapshot"
            ]
          },
          "error": {
            "type": "string",
            "description": "Error",
            "nullable": true
          }
        },
        "required": [
          "ok",
          "fetchedAt",
          "request",
          "status",
          "data"
        ]
      }
    }
  }
}
