  "components": {
    "schemas": {
      "PumpCoinSummary": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rank": {
            "type": "integer",
            "format": "int64",
            "description": "Row rank",
            "nullable": true
          },
          "source": {
            "type": "string",
            "description": "Source label"
          },
          "route": {
            "type": "string",
            "description": "Normalized local route",
            "nullable": true
          },
          "mint": {
            "type": "string",
            "description": "Token mint",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "Token name"
          },
          "symbol": {
