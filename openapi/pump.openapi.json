    "/api/pump/coin/dashboard": {
      "get": {
        "tags": [
          "Pump Coin"
        ],
        "summary": "Fetch the aggregated realtime Pump coin dashboard",
        "parameters": [
          {
            "name": "mint",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "26HijyQRPisA96er6xWLh32TSMAHLvivTnmcmu7bpump"
            },
            "description": "Pump token mint / contract address."
          },
          {
            "name": "candleInterval",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "1m",
                "5m",
                "15m",
                "30m",
                "1h",
                "6h",
                "24h"
              ],
              "default": "1h"
            }
          },
          {
            "name": "candlesLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 5,
              "maximum": 1000,
              "default": 120
            }
          },
          {
            "name": "tradesLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            }
          },
          {
            "name": "holdersLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          },
          {
            "name": "repliesLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000,
              "default": 25
            }
          },
          {
            "name": "clipsLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 12
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pump dashboard aggregate payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PumpDashboardResponse"
                }
              }
            }
          },
          "503": {
            "description": "Pump dashboard unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PumpDashboardResponse"
                }
              }
            }
          }
        }
      }
    },
