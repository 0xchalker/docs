    },
    "/api/pump/discover/recommended": {
      "get": {
        "tags": [
          "Pump Discover"
        ],
        "summary": "Fetch Pump recommended tokens",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 300,
              "default": 24
