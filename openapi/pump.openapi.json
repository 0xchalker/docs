{
  "openapi": "3.0.3",
  "info": {
    "title": "Pump API",
    "version": "1.0.0",
    "description": "Normalized local Pump.fun crawler API. Includes discover lists, route-derived live lists, and token-level detail endpoints for the realtime Pump dashboard."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3002",
      "description": "Local API server"
    }
  ],
  "tags": [
    {
      "name": "Pump Discover",
      "description": "Pump discover and live-list endpoints"
    },
    {
      "name": "Pump Coin",
      "description": "Pump token detail endpoints"
    }
  ],
  "paths": {
    "/api/pump/discover/dashboard": {
      "get": {
        "tags": [
          "Pump Discover"
        ],
        "summary": "Fetch the full Pump discover dashboard",
        "parameters": [
          {
            "name": "topRunnersLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60,
              "default": 12
            }
          },
          {
            "name": "recommendedLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60,
              "default": 12
            }
          },
          {
            "name": "liveLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60,
              "default": 12
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregated Pump discover dashboard payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PumpDiscoverDashboardResponse"
                }
              }
            }
          },
          "503": {
            "description": "Pump discover sources unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PumpDiscoverDashboardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/pump/discover/top-runners": {
      "get": {
        "tags": [
          "Pump Discover"
        ],
        "summary": "Fetch Pump top-runners",
        "parameters": [
