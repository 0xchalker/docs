            }
          }
        }
      }
    },
    "/api/gmgn/token/chart": {
      "get": {
        "tags": [
          "GMGN Token"
        ],
        "summary": "Chart candles",
        "description": "Candles for the GMGN token detail chart.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
            },
            "example": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
          },
          {
            "name": "resolution",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "1s",
