{
  "openapi": "3.0.3",
  "info": {
    "title": "GMGN Token API",
    "version": "2.1.0",
    "description": "Token API grouped by page overview, chart, and individual GMGN token-detail scopes. The local terminal renders Trades, Holders, Top Traders, Liquidity Pool, and Dev Token from section endpoints. DCA, Positions, and Orders remain direct API checks only. Keep /api/gmgn/token only for legacy compatibility."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3002",
      "description": "Local API server"
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "Server health and crawler runtime state"
    },
    {
      "name": "GMGN Token",
      "description": "Token detail sections grouped by overview, chart, and tab-level data"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Check API server health",
        "responses": {
          "200": {
            "description": "Health payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/token": {
      "get": {
        "tags": [
          "GMGN Token"
        ],
        "summary": "Legacy aggregated token payload",
        "description": "Backward-compatible aggregate used by the current local token UI. Prefer section endpoints below for accurate tab scope.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
            },
            "example": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
          },
          {
            "name": "resolution",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "1s",
                "30s",
                "1m",
                "1h",
                "4h",
                "1d"
              ],
              "default": "1m"
            }
          },
          {
            "name": "tradesLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 8,
              "maximum": 80,
              "default": 18
            }
          },
          {
            "name": "holdersLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 8,
              "maximum": 80,
              "default": 30
            }
          },
          {
            "name": "candlesLimit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 20,
              "maximum": 240,
              "default": 90
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Legacy payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LegacyTokenPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/token/overview": {
      "get": {
        "tags": [
          "GMGN Token"
        ],
        "summary": "Overview/header data",
        "description": "Page-level token identity, headline KPIs, security, pool, and page badges. These counts are not the same as holders/traders tab counts.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
            },
            "example": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
          }
        ],
        "responses": {
          "200": {
            "description": "Section payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler/session unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/token/links": {
      "get": {
        "tags": [
          "GMGN Token"
        ],
        "summary": "Header social and external links",
        "description": "Live token header links crawled from the GMGN token page. Returns `website`, `x`, `github`, and `telegram` when the source page exposes them.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
            },
            "example": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
          }
        ],
        "responses": {
          "200": {
            "description": "Section payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          },
          "503": {
