                }
              }
            }
          },
          "503": {
            "description": "Crawler/session unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/token/trades": {
      "get": {
        "tags": [
          "GMGN Token"
        ],
        "summary": "Trades tab base feed",
        "description": "Base trade tape for the Trades tab. GMGN trade chips are UI state on top of this feed, so counts like `Smart 7` should not be reused for Holders or Top Traders.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
            },
            "example": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 10,
              "maximum": 200,
              "default": 100
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "fetchAll",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Follow upstream `next` cursors and merge multiple batches into one response."
          },
          {
            "name": "maxPages",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 12
            },
            "description": "Maximum upstream pages to merge when `fetchAll=true`. If the response still has `data.summary.pagination.has_more=true`, the scan hit this cap."
          }
        ],
        "responses": {
          "200": {
            "description": "Section payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler/session unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/token/holders": {
      "get": {
        "tags": [
          "GMGN Token"
        ],
        "summary": "Holders tab",
        "description": "Holders table and holder summary metrics. `filter` is tab-scoped and maps to upstream tag params like `smart_degen`, `blue_chip`, `bundler`. Counts here can differ from the Trades tab even when the chip label is the same.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
            },
            "example": "HmKhuB9CDoHhg829K8KGxfUSy1sP3pAttswi9JG1DKJa"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 10,
              "maximum": 200,
              "default": 100
            }
          },
          {
            "name": "orderBy",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "amount_percentage"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "renowned",
                "dev",
                "smart_degen",
                "blue_chip",
                "fresh_wallet",
                "sniper",
                "rat_trader",
                "transfer_in",
                "dex_bot",
                "bundler"
              ],
              "nullable": true
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "fetchAll",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Follow upstream `next` cursors and merge multiple batches into one response."
          },
          {
            "name": "maxPages",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 12
            },
            "description": "Maximum upstream pages to merge when `fetchAll=true`. If the response still has `data.summary.pagination.has_more=true`, the scan hit this cap."
          }
        ],
        "responses": {
          "200": {
            "description": "Section payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler/session unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSectionPayload"
                }
              }
            }
          }
        }
      }
    },
