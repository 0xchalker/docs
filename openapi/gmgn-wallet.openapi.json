{
  "openapi": "3.0.3",
  "info": {
    "title": "GMGN Wallet API",
    "version": "1.0.0",
    "description": "Normalized GMGN wallet endpoints backed by a browser-aware wallet crawler. The public surface is organized by wallet page sections: profile, stats, holdings, activity, and rankings."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3002",
      "description": "Local API server"
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "Server health and crawler runtime status"
    },
    {
      "name": "GMGN Wallet",
      "description": "Normalized GMGN wallet data grouped by logical wallet page sections"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Check API server health",
        "responses": {
          "200": {
            "description": "Server health payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/wallet": {
      "get": {
        "tags": [
          "GMGN Wallet"
        ],
        "summary": "Fetch the compatibility aggregate wallet payload",
        "description": "Composed wallet response bundling profile, stats, holdings, activity, and rankings.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "1d",
                "7d",
                "30d",
                "all"
              ],
              "default": "7d"
            }
          },
          {
            "name": "holdingsLimit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 8,
              "maximum": 80,
              "default": 50
            }
          },
          {
            "name": "activityLimit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 8,
              "maximum": 120,
              "default": 40
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Composed wallet payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler unavailable or blocked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/wallet/profile": {
      "get": {
        "tags": [
          "GMGN Wallet"
        ],
        "summary": "Fetch wallet identity and social profile",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "1d",
                "7d",
                "30d",
                "all"
              ],
              "default": "7d"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet profile payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletProfilePayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler unavailable or blocked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/wallet/stats": {
      "get": {
        "tags": [
          "GMGN Wallet"
        ],
        "summary": "Fetch wallet overall stats",
        "description": "Canonical summary endpoint for total wallet metrics such as value, PnL, win rate, token counts, fees, volume, and PnL bucket breakdowns.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "1d",
                "7d",
                "30d",
                "all"
              ],
              "default": "7d"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet stats payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletStatsPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler unavailable or blocked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/wallet/holdings": {
      "get": {
        "tags": [
          "GMGN Wallet"
        ],
        "summary": "Fetch normalized GMGN wallet holdings",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 8,
              "maximum": 80,
              "default": 50
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orderBy",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "last_active_timestamp"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "desc"
            }
          },
          {
            "name": "hideSmall",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "sellout",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "hideAbnormal",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Holdings payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletHoldingsPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler unavailable or blocked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/wallet/activity": {
      "get": {
        "tags": [
          "GMGN Wallet"
        ],
        "summary": "Fetch normalized GMGN wallet activity feed",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
            }
          },
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "1d",
                "7d",
                "30d",
                "all"
              ],
              "nullable": true
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 8,
              "maximum": 120,
              "default": 40
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Activity payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletActivityPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler unavailable or blocked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gmgn/wallet/rankings": {
      "get": {
        "tags": [
          "GMGN Wallet"
        ],
        "summary": "Fetch wallet ranking sections",
        "description": "Returns recovered ranking blocks such as pnl_gt_5x. Market-cap ranking stays nullable until the upstream type enum is fully recovered.",
        "parameters": [
          {
            "name": "chain",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "sol"
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "1d",
                "7d",
                "30d",
                "all"
              ],
              "default": "7d"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet rankings payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletRankingsPayload"
                }
              }
            }
          },
          "503": {
            "description": "Crawler unavailable or blocked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GmgnWalletErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CrawlerStatus": {
        "type": "object",
        "required": [
          "connected",
          "ready",
          "pageUrl",
          "profileDir",
          "lastPageTitle",
          "lastSnapshotAt",
          "lastReconnectAt",
          "lastError"
        ],
        "properties": {
          "connected": {
            "type": "boolean"
          },
          "ready": {
            "type": "boolean"
          },
          "pageUrl": {
            "type": "string"
          },
          "profileDir": {
            "type": "string"
          },
          "lastPageTitle": {
            "type": "string"
          },
          "lastSnapshotAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "lastReconnectAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "lastError": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "ok",
          "service",
          "now",
          "status"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string",
            "example": "gmgn-api"
          },
          "now": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "$ref": "#/components/schemas/CrawlerStatus"
          }
        }
      },
      "GmgnWalletSectionRequest": {
        "type": "object",
        "required": [
          "chain",
          "address",
          "period"
        ],
        "properties": {
          "chain": {
            "type": "string",
            "example": "sol"
          },
          "address": {
            "type": "string",
            "example": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
          },
          "period": {
            "type": "string",
            "enum": [
              "1d",
              "7d",
              "30d",
              "all"
            ]
          }
        }
      },
      "GmgnWalletRequest": {
        "type": "object",
        "required": [
          "chain",
          "address",
          "period",
          "holdingsLimit",
          "activityLimit"
        ],
        "properties": {
          "chain": {
            "type": "string",
            "example": "sol"
          },
          "address": {
            "type": "string",
            "example": "2tgUbS9UMoQD6GkDZBiqKYCURnGrSb6ocYwRABrSJUvY"
          },
          "period": {
            "type": "string",
            "enum": [
              "1d",
              "7d",
              "30d",
              "all"
            ]
          },
          "holdingsLimit": {
            "type": "integer"
          },
          "activityLimit": {
            "type": "integer"
          }
        }
      },
      "GmgnWalletHoldingsRequest": {
        "type": "object",
        "required": [
          "chain",
          "address",
          "limit",
          "cursor",
          "orderBy",
          "direction",
          "hideSmall",
          "sellout",
          "hideAbnormal"
        ],
        "properties": {
          "chain": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "cursor": {
            "type": "string",
            "nullable": true
          },
          "orderBy": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "hideSmall": {
            "type": "boolean"
          },
          "sellout": {
            "type": "boolean"
          },
          "hideAbnormal": {
            "type": "boolean"
          }
        }
      },
      "GmgnWalletActivityRequest": {
        "type": "object",
        "required": [
          "chain",
          "address",
          "period",
          "limit",
          "cursor"
        ],
        "properties": {
          "chain": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "period": {
            "type": "string",
            "nullable": true
          },
          "limit": {
            "type": "integer"
          },
          "cursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "GmgnWalletProfile": {
        "type": "object",
        "required": [
          "address",
          "addressLabel",
          "name",
          "displayName",
          "avatarUrl",
          "ens",
          "tag",
          "tags",
          "twitterName",
          "twitterUsername",
          "twitterDescription",
          "twitterFans",
          "followersCount",
          "followCount",
          "remarkCount",
          "createdTokenCount",
          "fundFrom",
          "fundFromAddress",
          "fundAmount",
          "fundTxHash",
          "fundFromAt",
          "isBlueVerified",
          "isTwitterBound"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "addressLabel": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "ens": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "twitterName": {
            "type": "string"
          },
          "twitterUsername": {
            "type": "string"
          },
          "twitterDescription": {
            "type": "string"
          },
          "twitterFans": {
            "type": "number",
            "nullable": true,
            "description": "Twitter fan count"
          },
          "followersCount": {
            "type": "number",
            "nullable": true,
            "description": "Follower count"
          },
          "followCount": {
            "type": "number",
            "nullable": true,
            "description": "Following count"
          },
          "remarkCount": {
            "type": "number",
            "nullable": true,
            "description": "Remark count"
          },
          "createdTokenCount": {
            "type": "number",
            "nullable": true,
            "description": "Created token count"
          },
          "fundFrom": {
            "type": "string"
          },
          "fundFromAddress": {
            "type": "string"
          },
          "fundAmount": {
            "type": "number",
            "nullable": true,
            "description": "Funding amount"
          },
          "fundTxHash": {
            "type": "string"
          },
          "fundFromAt": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Funding timestamp in milliseconds"
          },
          "isBlueVerified": {
            "type": "boolean"
          },
          "isTwitterBound": {
            "type": "boolean"
          }
        }
      },
      "GmgnWalletPnlBreakdown": {
        "type": "object",
        "required": [
          "winRate",
          "tokenCount",
          "profitTokenCount",
          "pnlLtMinusHalfCount",
          "pnlMinusHalfToZeroCount",
          "pnlZeroTo2xCount",
          "pnl2xTo5xCount",
          "pnlGt5xCount",
          "firstMarketCapBucket",
          "secondMarketCapBucket",
          "thirdMarketCapBucket"
        ],
        "properties": {
          "winRate": {
            "type": "number",
            "nullable": true,
            "description": "Win rate percentage"
          },
          "tokenCount": {
            "type": "number",
            "nullable": true,
            "description": "Token count"
          },
          "profitTokenCount": {
            "type": "number",
            "nullable": true,
            "description": "Profit token count"
          },
          "pnlLtMinusHalfCount": {
            "type": "number",
            "nullable": true,
            "description": "PnL below -50% bucket count"
          },
          "pnlMinusHalfToZeroCount": {
            "type": "number",
            "nullable": true,
            "description": "PnL between -50% and 0% bucket count"
          },
          "pnlZeroTo2xCount": {
            "type": "number",
            "nullable": true,
            "description": "PnL between 0% and 200% bucket count"
          },
          "pnl2xTo5xCount": {
            "type": "number",
            "nullable": true,
            "description": "PnL between 200% and 500% bucket count"
          },
          "pnlGt5xCount": {
            "type": "number",
            "nullable": true,
            "description": "PnL above 500% bucket count"
          },
          "firstMarketCapBucket": {
            "type": "number",
            "nullable": true,
            "description": "First market-cap bucket count"
          },
          "secondMarketCapBucket": {
            "type": "number",
            "nullable": true,
            "description": "Second market-cap bucket count"
          },
          "thirdMarketCapBucket": {
            "type": "number",
            "nullable": true,
            "description": "Third market-cap bucket count"
          }
        }
      },
      "GmgnWalletStats": {
        "type": "object",
        "required": [
          "chain",
          "address",
          "addressLabel",
          "balanceNative",
          "totalValueUsd",
          "totalVolumeUsd",
          "realizedProfitUsd",
          "realizedProfitPnl",
          "unrealizedProfitUsd",
          "unrealizedProfitPnl",
          "totalProfitUsd",
          "totalProfitPnl",
          "winRate",
          "tokenCount",
          "profitTokenCount",
          "followCount",
          "remarkCount",
          "lastActiveAt",
          "fundFrom",
          "fundFromAddress",
          "fundFromAt",
          "fundAmount",
          "totalBuys",
          "totalSells",
          "totalBoughtCostUsd",
          "totalSoldIncomeUsd",
          "totalFeeNative",
          "totalFeeUsd",
          "avgHoldingPeriodSeconds",
          "tags",
          "pnlBreakdown"
        ],
        "properties": {
          "chain": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "addressLabel": {
            "type": "string"
          },
          "balanceNative": {
            "type": "number",
            "nullable": true,
            "description": "Native token balance"
          },
          "totalValueUsd": {
            "type": "number",
            "nullable": true,
            "description": "Total value in USD"
          },
          "totalVolumeUsd": {
            "type": "number",
            "nullable": true,
            "description": "Total volume in USD"
          },
          "realizedProfitUsd": {
            "type": "number",
            "nullable": true,
            "description": "Realized profit in USD"
          },
          "realizedProfitPnl": {
            "type": "number",
            "nullable": true,
            "description": "Realized profit percentage"
          },
          "unrealizedProfitUsd": {
            "type": "number",
            "nullable": true,
            "description": "Unrealized profit in USD"
          },
          "unrealizedProfitPnl": {
            "type": "number",
            "nullable": true,
            "description": "Unrealized profit percentage"
          },
          "totalProfitUsd": {
            "type": "number",
            "nullable": true,
            "description": "Total profit in USD"
          },
          "totalProfitPnl": {
            "type": "number",
            "nullable": true,
            "description": "Total profit percentage"
          },
          "winRate": {
            "type": "number",
            "nullable": true,
            "description": "Win rate percentage"
          },
          "tokenCount": {
            "type": "number",
            "nullable": true,
            "description": "Token count"
          },
          "profitTokenCount": {
            "type": "number",
            "nullable": true,
            "description": "Profit token count"
          },
          "followCount": {
            "type": "number",
            "nullable": true,
            "description": "Follow count"
          },
          "remarkCount": {
            "type": "number",
            "nullable": true,
            "description": "Remark count"
          },
          "lastActiveAt": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Last activity timestamp in milliseconds"
          },
          "fundFrom": {
            "type": "string"
          },
          "fundFromAddress": {
            "type": "string"
          },
          "fundFromAt": {
            "type": "integer",
